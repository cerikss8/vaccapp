<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}VaccApp{% endblock %}</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- (Valfritt) Din egen CSS -->
  {# <link rel="stylesheet" href="{{ url_for('static', filename='css/styles.css') }}"> #}

  <style>
    /* Liten SaaS-känsla utan att förstöra din befintliga design */
    .navbar-brand { letter-spacing: .2px; }
  </style>
</head>

<body class="d-flex flex-column min-vh-100 bg-light">

  {% if show_navbar %}
  <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="{{ url_for('main.dashboard') }}">
        VaccApp
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
              aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNavbar">

        <ul class="navbar-nav me-auto">
          {% if current_user.is_authenticated %}
            <li class="nav-item">
              <a class="nav-link" href="{{ url_for('main.dashboard') }}">Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="{{ url_for('main.profile') }}">Profil</a>
            </li>

            {% if current_user.is_admin %}
              <li class="nav-item">
                <a class="nav-link" href="{{ url_for('admin.users') }}">Admin</a>
              </li>
            {% endif %}
          {% else %}
            <li class="nav-item">
              <a class="nav-link" href="{{ url_for('main.index') }}">Start</a>
            </li>
          {% endif %}
        </ul>

        <ul class="navbar-nav ms-auto">
          {% if current_user.is_authenticated %}
            <li class="nav-item">
              <a class="nav-link" href="{{ url_for('auth.logout') }}">Logga ut</a>
            </li>
          {% else %}
            <li class="nav-item">
              <a class="nav-link" href="{{ url_for('auth.login') }}">Logga in</a>
            </li>
            <li class="nav-item">
              <a class="btn btn-primary ms-lg-2" href="{{ url_for('auth.register') }}">Registrera</a>
            </li>
          {% endif %}
        </ul>

      </div>
    </div>
  </nav>
  {% endif %}

  <!-- Main content -->
  <main class="flex-grow-1">
    <div class="container py-4">

      <!-- Flash messages -->
      {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
          <div class="mb-3">
            {% for category, message in messages %}
              {# Mappar dina flash-kategorier till bootstrap #}
              {% set bs = "info" %}
              {% if category in ["success","warning","danger","info","primary","secondary","dark","light"] %}
                {% set bs = category %}
              {% endif %}
              <div class="alert alert-{{ bs }} mb-2" role="alert">
                {{ message }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      {% endwith %}

      {% block content %}{% endblock %}

    </div>
  </main>

  <!-- SaaS footer (sticky via body flex + main flex-grow-1) -->
  <footer class="border-top bg-white">
    <div class="container py-4">

      <div class="row g-4 align-items-start">

        <!-- Brand -->
        <div class="col-12 col-md-5">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="fw-bold fs-5">VaccApp</span>
            <span class="badge bg-light text-dark border">CEME Smart System</span>
          </div>
          <p class="text-muted mb-0">
            Hantera vaccinationer enkelt och säkert för hela familjen.
          </p>
        </div>

        <!-- Links -->
        <div class="col-6 col-md-3">
          <div class="fw-semibold mb-2">Produkt</div>
          <ul class="list-unstyled mb-0">
            <li>
              <a class="text-decoration-none text-muted" href="{{ url_for('main.dashboard') }}">Dashboard</a>
            </li>
            <li>
              <a class="text-decoration-none text-muted" href="{{ url_for('main.profile') }}">Profil</a>
            </li>
            {% if current_user.is_authenticated %}
              <li>
                <a class="text-decoration-none text-muted" href="{{ url_for('main.add_person') }}">Lägg till barn/person</a>
              </li>
            {% endif %}
          </ul>
        </div>

        <!-- Support -->
        <div class="col-6 col-md-4">
          <div class="fw-semibold mb-2">Support</div>
          <div class="text-muted">
            <div class="mb-1">E-post:</div>
            <a class="text-decoration-none" href="mailto:support@vaccapp.com">
              support@vaccapp.com
            </a>
          </div>
        </div>

      </div>

      <hr class="my-4">

      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
        <div class="text-muted small">
          © 2026 VaccApp • Alla rättigheter förbehållna
        </div>

        <div class="d-flex gap-3 small">
          <a class="text-decoration-none text-muted" href="#">Privacy</a>
          <a class="text-decoration-none text-muted" href="#">Terms</a>
          <a class="text-decoration-none text-muted" href="mailto:support@vaccapp.com">Kontakt</a>
        </div>
      </div>

    </div>
  </footer>

  <!-- Bootstrap JS bundle (krävs för dropdown/navbar toggler) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>